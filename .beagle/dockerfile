ARG BASE=nvidia/cuda:13.2.1-runtime-ubuntu24.04
FROM nvidia/cuda:13.2.1-devel-ubuntu24.04 AS kernel-builder

RUN apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get update \
    && apt-get install -y --no-install-recommends python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY src/worker.py /app/src/worker.py
COPY tools/extract_postprocess_kernel.py /app/tools/extract_postprocess_kernel.py
RUN python3 /app/tools/extract_postprocess_kernel.py \
        --worker /app/src/worker.py \
        --output /tmp/postprocess.cu \
    && nvcc \
        --ptx \
        --std=c++17 \
        --use_fast_math \
        -arch=compute_89 \
        /tmp/postprocess.cu \
        -o /tmp/postprocess.ptx

FROM nvidia/cuda:13.2.1-devel-ubuntu24.04 AS bridge-builder

RUN apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        pkg-config \
        libavcodec-dev \
        libavformat-dev \
        libavutil-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY src/native/ffmpeg_cuda_chw_bridge.cu /app/src/native/ffmpeg_cuda_chw_bridge.cu
RUN nvcc /app/src/native/ffmpeg_cuda_chw_bridge.cu \
        -o /tmp/libffmpeg_cuda_chw_bridge.so \
        --shared \
        -Xcompiler -fPIC \
        --std=c++17 \
        -arch=sm_89 \
        -Xcompiler "$(pkg-config --cflags libavformat libavcodec libavutil)" \
        $(pkg-config --libs libavformat libavcodec libavutil) \
        -lcuda

FROM ${BASE}

ARG AUTHOR
ARG VERSION
LABEL maintainer=${AUTHOR} version=${VERSION}

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    PYTHONUNBUFFERED=1

RUN apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        ffmpeg \
        python-is-python3 \
        python3 \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY src /app/src
COPY --from=kernel-builder /tmp/postprocess.ptx /app/src/postprocess.ptx
COPY --from=bridge-builder /tmp/libffmpeg_cuda_chw_bridge.so /app/src/libffmpeg_cuda_chw_bridge.so
COPY .beagle/hooks/nvenc_ioctl_hook.so /opt/hooks/nvenc_ioctl_hook.so
COPY requirements.txt /app/requirements.txt

RUN python3 -m pip install --no-cache-dir --no-compile --break-system-packages \
        -r /app/requirements.txt \
    && site_packages="$(python3 -c 'import site; print(site.getsitepackages()[0])')" \
    && if [ -d "${site_packages}/tensorrt_libs" ]; then \
        find "${site_packages}/tensorrt_libs" -maxdepth 1 -type f \( \
            -name "libnvinfer_builder_resource*.so*" -o \
            -name "libnvinfer_dispatch.so*" -o \
            -name "libnvinfer_lean.so*" -o \
            -name "libnvinfer_vc_plugin.so*" \
        \) -delete; \
    fi \
    && find "${site_packages}" -type d -name "__pycache__" -prune -exec rm -rf {} + \
    && python3 -c "import tensorrt" \
    && mkdir -p /models

COPY .beagle/entrypoint.sh /usr/local/bin/video2x-entrypoint
RUN chmod +x /usr/local/bin/video2x-entrypoint /opt/hooks/nvenc_ioctl_hook.so

RUN if [ -f /etc/apt/sources.list.d/ubuntu.sources ]; then \
        sed -i \
          's|http://archive.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g; s|http://security.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' \
          /etc/apt/sources.list.d/ubuntu.sources; \
    elif [ -f /etc/apt/sources.list ]; then \
        sed -i \
          's|http://archive.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g; s|http://security.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' \
          /etc/apt/sources.list; \
    fi \
    && mkdir -p /etc/pip \
    && printf '%s\n' \
        '[global]' \
        'index-url = https://mirrors.aliyun.com/pypi/simple/' \
        'trusted-host = mirrors.aliyun.com' \
        > /etc/pip.conf

ENV NVIDIA_DRIVER_CAPABILITIES=video,compute,utility \
    DATA_DIR=/data \
    TARGET_WIDTH=1920 \
    TARGET_HEIGHT=1080 \
    MODEL_NAME=auto \
    TILE=0 \
    GPU_ID=0 \
    RUNNER=trt-cuda \
    VIDEO_ENCODER=hevc_nvenc \
    VIDEO_BITRATE=5M \
    VIDEO_PIXEL_FORMAT=nv12 \
    VIDEO_GOP_SIZE=60 \
    PIPELINE_DEPTH=2 \
    VIDEO_INPUT_MODE=rgb24 \
    VIDEO_OUTPUT_MODE=stdin \
    VIDEO_POSTPROCESS_MODE=engine-output \
    SRVGG_TAIL_KERNEL=2x2-rgb \
    CUDA_P010_BRIDGE=/app/src/libffmpeg_cuda_chw_bridge.so \
    CUDA_NVENC_BRIDGE=/app/src/libffmpeg_cuda_chw_bridge.so \
    OUTPUT_SUFFIX=_1080p \
    SKIP_EXISTING=true \
    MODEL_DIR=/models \
    LD_PRELOAD=/opt/hooks/nvenc_ioctl_hook.so \
    TRT_CUDA_TOOL=/app/src/worker.py

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/video2x-entrypoint"]
