ARG BASE=nvidia/cuda:13.0.3-runtime-ubuntu24.04
FROM ${BASE}

ARG AUTHOR
ARG VERSION
LABEL maintainer=${AUTHOR} version=${VERSION}

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    PYTHONUNBUFFERED=1 \
    NVIDIA_DRIVER_CAPABILITIES=all \
    DATA_DIR=/data \
    TARGET_HEIGHT=1080 \
    MODEL_NAME=auto \
    TILE=0 \
    GPU_ID=0 \
    OUTPUT_SUFFIX=_1080p \
    SKIP_EXISTING=true \
    REALESRGAN_HOME=/app/realesrgan \
    MODEL_DIR=/models

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        ffmpeg \
        libglib2.0-0 \
        libgl1 \
        python-is-python3 \
        python3 \
        python3-pip \
        python3-dev \
        procps \
        wget \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir --break-system-packages \
        torch==2.10.0+cu130 \
        torchvision==0.25.0+cu130 \
        --extra-index-url https://download.pytorch.org/whl/cu130

WORKDIR /app

COPY src /app/src
COPY vendor/realesrgan "${REALESRGAN_HOME}"

RUN python3 -m pip install --no-cache-dir --break-system-packages -r "${REALESRGAN_HOME}/requirements.txt" \
    && python3 -m pip install --no-cache-dir --break-system-packages basicsr facexlib gfpgan ffmpeg-python \
    && mkdir -p "${MODEL_DIR}"

COPY .beagle/entrypoint.sh /usr/local/bin/video2x-entrypoint
RUN chmod +x /usr/local/bin/video2x-entrypoint

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/video2x-entrypoint"]
