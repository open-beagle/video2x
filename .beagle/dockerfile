ARG BASE=nvidia/cuda:13.2.1-runtime-ubuntu24.04
FROM ${BASE}

ARG AUTHOR
ARG VERSION
LABEL maintainer=${AUTHOR} version=${VERSION}

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    PYTHONUNBUFFERED=1 \
    NVIDIA_DRIVER_CAPABILITIES=video,compute,utility \
    DATA_DIR=/data \
    TARGET_WIDTH=1920 \
    TARGET_HEIGHT=1080 \
    MODEL_NAME=auto \
    TILE=0 \
    GPU_ID=0 \
    RUNNER=trt-cuda \
    VIDEO_ENCODER=hevc_nvenc \
    VIDEO_BITRATE=5M \
    VIDEO_PIXEL_FORMAT=nv12 \
    OUTPUT_SUFFIX=_1080p \
    SKIP_EXISTING=true \
    MODEL_DIR=/models \
    LD_PRELOAD=/opt/hooks/nvenc_ioctl_hook.so \
    NVENC_GPU_INDEX=0 \
    TRT_CUDA_TOOL=/app/src/worker.py

RUN apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        ffmpeg \
        python-is-python3 \
        python3 \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY src /app/src
COPY .beagle/hooks/nvenc_ioctl_hook.so /opt/hooks/nvenc_ioctl_hook.so

RUN python3 -m pip install --no-cache-dir --break-system-packages \
        cuda-python numpy tensorrt \
    && mkdir -p "${MODEL_DIR}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends cuda-nvrtc-13-2 libnvinfer10 \
    && rm -rf /var/lib/apt/lists/*

COPY .beagle/entrypoint.sh /usr/local/bin/video2x-entrypoint
RUN chmod +x /usr/local/bin/video2x-entrypoint /opt/hooks/nvenc_ioctl_hook.so

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/video2x-entrypoint"]
